# ──────────────────────────────────────────
# AI Workspace — environment variables
# Copy to .env and fill in the values.
# Never commit .env to version control.
# ──────────────────────────────────────────

# ── PostgreSQL ──────────────────────────
POSTGRES_DB=aiworkspace
POSTGRES_USER=aiworkspace
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ───────────────────────────────
REDIS_PASSWORD=change_me_strong_password

# ── JWT ─────────────────────────────────
# Must be at least 32 characters (256-bit).
JWT_SECRET=change_me_at_least_32_chars_long_secret
JWT_ACCESS_EXPIRATION_MS=900000      # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days

# ── AI Providers (optional in dev) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Spring Profile ───────────────────────
# Options: dev | prod
SPRING_PROFILES_ACTIVE=prod
